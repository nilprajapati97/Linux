# Kernel config fragment for ARM64 MM debug validation
# Merge with defconfig: scripts/kconfig/merge_config.sh -m .config this_file

# ── QEMU virt machine support ──────────────────────────────────────
CONFIG_ARCH_VIRT=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_MMIO=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_GIC_V3=y

# ── ARM64 page table config ───────────────────────────────────────
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_ARM64_VA_BITS=48
CONFIG_PGTABLE_LEVELS=4

# ── Disable KASLR for reproducible addresses ──────────────────────
# CONFIG_RANDOMIZE_BASE is not set

# ── Memory debugging — see every phase in dmesg ──────────────────
CONFIG_MEMBLOCK_DEBUG=y
CONFIG_DEBUG_VM=y
CONFIG_DEBUG_VM_PGTABLE=y
CONFIG_DEBUG_PAGEALLOC=y
CONFIG_DEBUG_PAGEALLOC_ENABLE_DEFAULT=y
CONFIG_PAGE_OWNER=y
CONFIG_PAGE_OWNER_ENABLE_DEFAULT=y
CONFIG_DEBUG_VIRTUAL=y

# ── SLUB/Slab debugging ──────────────────────────────────────────
CONFIG_SLUB=y
CONFIG_SLUB_DEBUG=y
CONFIG_SLUB_DEBUG_ON=y
CONFIG_SLUB_STATS=y

# ── Page table dump via debugfs ───────────────────────────────────
CONFIG_ARM64_PTDUMP_CORE=y
CONFIG_ARM64_PTDUMP_DEBUGFS=y
CONFIG_PTDUMP_CORE=y
CONFIG_PTDUMP_DEBUGFS=y
CONFIG_GENERIC_PTDUMP=y

# ── Proc/sys interfaces for memory inspection ────────────────────
CONFIG_PROC_PAGE_MONITOR=y
CONFIG_DEBUG_FS=y

# ── Symbol resolution (needed by modules) ─────────────────────────
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# ── Module support ────────────────────────────────────────────────
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y

# ── Dynamic debug messages ────────────────────────────────────────
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DYNAMIC_DEBUG_CORE=y

# ── Early printk ──────────────────────────────────────────────────
CONFIG_EARLY_PRINTK=y

# ── Debug info for GDB ────────────────────────────────────────────
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_GDB_SCRIPTS=y
CONFIG_DEBUG_KERNEL=y

# ── Initramfs support ────────────────────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Memtest ───────────────────────────────────────────────────────
CONFIG_MEMTEST=y

# ── CMA for DMA testing ──────────────────────────────────────────
CONFIG_CMA=y
CONFIG_CMA_DEBUG=y
CONFIG_DMA_CMA=y
CONFIG_CMA_SIZE_MBYTES=64

# ── NUMA (informational — QEMU virt is UMA) ──────────────────────
CONFIG_NUMA=y

# ── Printk timestamps ────────────────────────────────────────────
CONFIG_PRINTK_TIME=y

# ── Disable features that add noise ──────────────────────────────
# CONFIG_KASAN is not set
# CONFIG_KCSAN is not set
# CONFIG_LOCKDEP is not set
